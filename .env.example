OWNER=local
DEBUG=true
LOG_LEVEL=DEBUG

# Datastores are floci-simulated; hostnames resolve on todo-app-net (task docker:up).
DB_HOST=floci-rds-todo-aurora
DB_PORT=5432
DB_NAME=todo
DB_USER=todo
DB_PASSWORD=todopassword
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20

ATLAS_DIR=migrations

CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

CACHE_ENABLE=true
CACHE_NAMESPACES=users,tasks,ai
REDIS_HOST=floci-valkey-todo-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# AWS routed at floci (local emulator).
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://floci:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
COGNITO_USER_POOL_ID=us-east-1_example
COGNITO_APP_CLIENT_ID=exampleappclientid
COGNITO_DOMAIN=todo-app.auth.us-east-1.amazoncognito.com
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

OTEL_ENABLE=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=todo-app
