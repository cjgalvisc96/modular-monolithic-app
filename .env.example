# --- Identity / ownership ---
OWNER=local
DEBUG=true
LOG_LEVEL=DEBUG

# --- Database (PostgreSQL / asyncpg) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=todo
DB_USER=todo
DB_PASSWORD=todo
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20

# --- Atlas migrations ---
ATLAS_DIR=migrations

# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# --- Cache (Redis) ---
CACHE_ENABLE=true
CACHE_NAMESPACES=users,tasks,ai
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- AWS / Cognito / Bedrock ---
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_example
COGNITO_APP_CLIENT_ID=exampleappclientid
COGNITO_DOMAIN=todo-app.auth.us-east-1.amazoncognito.com
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# --- Observability (optional) ---
OTEL_ENABLE=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=todo-app
